{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["bun-types"],
    "paths": {
      "@frozenink/core": ["./packages/core/src/index.ts"],
      "@frozenink/core/*": ["./packages/core/src/*/index.ts"],
      "@frozenink/crawlers": ["./packages/crawlers/src/index.ts"],
      "@frozenink/mcp": ["./packages/mcp/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/crawlers" },
    { "path": "packages/mcp" },
    { "path": "packages/cli" },
    { "path": "packages/ui" }
  ],
  "files": []
}
