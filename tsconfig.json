{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["bun-types"]
  },
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/connectors" },
    { "path": "packages/mcp" },
    { "path": "packages/cli" },
    { "path": "packages/ui" }
  ],
  "files": []
}
